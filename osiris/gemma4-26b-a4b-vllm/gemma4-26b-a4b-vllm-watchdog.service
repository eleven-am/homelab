[Unit]
Description=Restart Gemma 4 26B A4B vLLM if the API is unhealthy
After=docker.service network-online.target gemma4-26b-a4b-vllm.service
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/royossai/services/gemma4-26b-a4b-vllm
ExecStart=/home/royossai/services/gemma4-26b-a4b-vllm/watchdog.sh
